{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["vitest/globals"]
  },
  "include": ["**/*.ts", "**/*.tsx", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "mobile",
    "the-drinkers-app",
    "my-ai-agent",
    "my-glow-app",
    "memorix-avids2",
    "memory-bank-mcp-alioshr",
    "codebase-memory-mcp-deusdata",
    "cursorpool-backup",
    "claude-skills-alirezarezvani",
    "awesome-agent-skills-itgoyo",
    "awesome-skills-gmh",
    "magic-mcp-21st",
    "Site-Sn33k",
    "thedrinkers",
    "thedrinkers20",
    "Cursor_ODAM",
    "venv-devin"
  ]
}
