{
  "version": 2,
  "name": "the-drinkers-site",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["fra1"],
  "env": {
    "NEXT_PUBLIC_SITE_URL": "https://thedrinkers.si",
    "NEXT_PUBLIC_SITE_NAME": "The Drinkers"
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  }
}
