# ============================================
# THE DRINKERS - ENVIRONMENT VARIABLES
# ============================================

# ============================================
# DATABASE (Required)
# ============================================
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ============================================
# BETTER AUTH (Required)
# ============================================
BETTER_AUTH_SECRET=your-secret-key-here-min-32-characters
BETTER_AUTH_URL=http://localhost:3000

# ============================================
# EMAIL - RESEND (Required)
# ============================================
RESEND_API_KEY=re_your-api-key-here

# ============================================
# PAYMENTS - STRIPE (Required)
# ============================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ============================================
# AI SERVICES (Choose ONE - Recommended: HuggingFace FREE)
# ============================================

# 🌟 HuggingFace API (RECOMMENDED - FREE tier available!)
# Get your FREE API key: https://huggingface.co/settings/tokens
# Free tier: 10k requests/month
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative: inference.sh (Premium - requires login)
# Install: curl -fsSL https://cli.inference.sh | sh && infsh login
INFERENCE_SH_API_KEY=

# Alternative: Replicate (Paid but cheap)
# REPLICATE_API_KEY=

# Fallback: Pollinations.ai (FREE, no key needed)
# Already integrated - no key required!

# ============================================
# OLLAMA - LOCAL AI (FREE - Optional)
# ============================================
OLLAMA_HOST=http://localhost:11434
