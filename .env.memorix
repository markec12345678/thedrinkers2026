# Memorix Environment Variables
# The Drinkers Project

# Optional: API keys for enhanced features
# MEMORIX_API_KEY=your-api-key-here

# Optional: Dashboard settings
# MEMORIX_DASHBOARD_PORT=3211

# Optional: Memory retention (days)
# MEMORIX_GIT_RETENTION=90
# MEMORIX_REASONING_RETENTION=60
# MEMORIX_OBSERVATION_RETENTION=30
# MEMORIX_SESSION_RETENTION=7

# Optional: Logging
# MEMORIX_LOG_LEVEL=info
# MEMORIX_LOG_FILE=logs/memorix.log
