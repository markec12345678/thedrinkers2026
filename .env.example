# ============================================
# THE DRINKERS - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# Run `npm run env:check` to validate your configuration
# ============================================

# ============================================
# DATABASE (Required)
# ============================================
# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Optional: Neon API for programmatic database management
# NEON_API_KEY=napi_xxx
# NEON_PROJECT_ID=ep-xxx

# ============================================
# BETTER AUTH (Required)
# ============================================
# Must be at least 32 characters - generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here-min-32-characters

# Your application URL (change in production)
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated emails allowed to access /admin and admin-only API routes
# Example: ADMIN_EMAILS=admin@thedrinkers.si,ops@thedrinkers.si
# ADMIN_EMAILS=

# Optional OAuth providers
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ============================================
# EMAIL - RESEND (Required)
# ============================================
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key-here

# ============================================
# PAYMENTS - STRIPE (Required)
# ============================================
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# For webhook signature verification (production)
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ============================================
# ANALYTICS (Optional but Recommended)
# ============================================
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Analytics (if using Vercel)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=XXXXXXXXXX

# ============================================
# AI SERVICES (Optional)
# ============================================
# OpenAI API Key - get from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key

# Anthropic API Key - get from https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google AI API Key - get from https://makersuite.google.com/app/apikey
# GOOGLE_AI_API_KEY=your-google-ai-key

# ============================================
# OLLAMA - LOCAL AI (Optional)
# ============================================
# Run Ollama locally: https://ollama.com
OLLAMA_HOST=http://localhost:11434

# ============================================
# MCP SERVERS (Optional)
# ============================================
# GitHub Personal Access Token for MCP GitHub integration
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your-github-token

# ============================================
# MEMORIX (Optional)
# ============================================
# AI memory service
# MEMORIX_API_KEY=your-memorix-key

# ============================================
# DEVELOPMENT (Required)
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
