# ====================================
# The Drinkers - Environment Variables Template
# ====================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to Git!

# ====================================
# 📊 Analytics
# ====================================

# Vercel Analytics (get from vercel.com/dashboard)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=

# ====================================
# 🎵 Music Integrations
# ====================================

# Spotify API (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube API (https://console.cloud.google.com/apis/credentials)
YOUTUBE_API_KEY=

# ====================================
# 🎫 Event/Ticketing
# ====================================

# Eventim API (or your ticketing provider)
EVENTIM_API_URL=https://api.eventim.si
EVENTIM_API_KEY=

# ====================================
# 🔐 Authentication (for /bar route)
# ====================================

# NextAuth.js secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ====================================
# 🌐 Site Configuration
# ====================================

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="The Drinkers"

# ====================================
# 📧 Email (for contact form)
# ====================================

# Resend (https://resend.com)
RESEND_API_KEY=

# Or SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ====================================
# 🗺️ Maps
# ====================================

# Google Maps API (optional, using Leaflet by default)
GOOGLE_MAPS_API_KEY=

# ====================================
# 📱 Social Media URLs
# ====================================

NEXT_PUBLIC_SPOTIFY_URL=https://open.spotify.com/artist/thedrinkers
NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@thedrinkers
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/thedrinkers
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/thedrinkers
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@thedrinkers

# ====================================
# 📞 Contact Information
# ====================================

NEXT_PUBLIC_CONTACT_EMAIL=info@thedrinkers.si
NEXT_PUBLIC_CONTACT_PHONE=+386 40 123 456
NEXT_PUBLIC_CONTACT_LOCATION=Ljubljana, Slovenija

# ====================================
# 🚀 Feature Flags
# ====================================

# Enable/disable features
NEXT_PUBLIC_ENABLE_BAR_PROTECTION=true
NEXT_PUBLIC_ENABLE_NEWSLETTER=true
NEXT_PUBLIC_ENABLE_MERCH_STORE=true

# ====================================
# 🔧 Development
# ====================================

NODE_ENV=development
