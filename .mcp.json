{
  "mcpServers": {
    "gmail": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "Gmail"],
      "env": {}
    },
    "googlecalendar": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "Google Calendar"],
      "env": {}
    },
    "notion": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "Notion"],
      "env": {}
    },
    "linear": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "Linear"],
      "env": {}
    },
    "airtable": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "Airtable"],
      "env": {}
    },
    "youtube": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "YouTube"],
      "env": {}
    },
    "sentry": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "Sentry"],
      "env": {}
    },
    "microsoft_teams": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "Microsoft Teams"],
      "env": {}
    },
    "asana": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "Asana"],
      "env": {}
    },
    "linkedin": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "LinkedIn"],
      "env": {}
    },
    "google_maps": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "Google Maps"],
      "env": {}
    },
    "spotify": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-spotify"],
      "env": {
        "SPOTIFY_CLIENT_ID": "${SPOTIFY_CLIENT_ID}",
        "SPOTIFY_CLIENT_SECRET": "${SPOTIFY_CLIENT_SECRET}"
      }
    },
    "discord": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-discord"],
      "env": {
        "DISCORD_BOT_TOKEN": "${DISCORD_BOT_TOKEN}"
      }
    },
    "stripe": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-stripe"],
      "env": {
        "STRIPE_SECRET_KEY": "${STRIPE_SECRET_KEY}"
      }
    },
    "resend": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-resend"],
      "env": {
        "RESEND_API_KEY": "${RESEND_API_KEY}"
      }
    }
  }
}
